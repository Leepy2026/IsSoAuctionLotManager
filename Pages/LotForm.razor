@page "/lots/new"
@page "/lots/edit/{Id:guid}"
@using Microsoft.AspNetCore.Components.Forms
@using AuctionLotManager.Models
@inject IAuctionLotService LotService
@inject NavigationManager Navigation
@inject IWebHostEnvironment Env

<PageTitle>@(IsEditMode ? "Edit Lot" : "Add Lot")</PageTitle>

<nav class="breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <a href="/">Edit</a>
    <span>›</span>
    <span class="breadcrumb-current">@model?.Title</span>
</nav>

<h1 class="page-title">@(IsEditMode ? "Edit Lot" : "Add New Lot")</h1>

<div class="card-panel form-panel">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <EditForm Model="model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-grid">
            <div>
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="model.Title" />
                <ValidationMessage For="@(() => model.Title)" />
            </div>

            <div>
                <label class="form-label">Category</label>
                <InputSelect class="form-control" @bind-Value="model.Category">
                    @foreach (var category in Enum.GetValues<Category>())
                    {
                        <option value="@category.ToString()">@category</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.Category)" />
            </div>

            <div class="full-width">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="model.Description" rows="4" />
                <ValidationMessage For="@(() => model.Description)" />
            </div>

            <div>
                <label class="form-label">Starting Price</label>
                <InputNumber class="form-control" @bind-Value="model.StartingPrice" />
                <ValidationMessage For="@(() => model.StartingPrice)" />
            </div>

            <div>
                <label class="form-label">Reserve Price</label>
                <InputNumber class="form-control" @bind-Value="model.ReservePrice" />
                <ValidationMessage For="@(() => model.ReservePrice)" />
            </div>

            <div>
                <label class="form-label">Start Date (UTC)</label>
                <InputDate class="form-control" @bind-Value="startDate" />
            </div>

            <div>
                <label class="form-label">End Date (UTC)</label>
                <InputDate class="form-control" @bind-Value="endDate" />
            </div>

            <div class="full-width">
                <label class="form-label">Lot Image</label>
                <InputFile OnChange="HandleImageUploadAsync" accept="image/*" class="form-control" />

                @if (!string.IsNullOrWhiteSpace(uploadErrorMessage))
                {
                    <div class="text-danger mt-2">@uploadErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(model.ImageFileName))
                {
                    <div class="mt-3">
                        <img src="@GetImageUrl(model.ImageFileName)"
                             alt="Lot preview"
                             style="max-width: 180px; max-height: 180px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                    </div>
                }
            </div>
        </div>

        <div class="toolbar-actions mt-4">
            <button class="btn btn-outline-secondary" type="button" @onclick='() => Navigation.NavigateTo("/")'>Cancel</button>
            <button class="btn btn-primary" type="submit" disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>@(IsEditMode ? "Save Changes" : "Create Lot")</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private LotUpsertModel model = new();
    private string? errorMessage;
    private string? uploadErrorMessage;
    private bool isSaving;

    private DateTime startDate
    {
        get => model.StartTime;
        set => model.StartTime = DateTime.SpecifyKind(value.Date, DateTimeKind.Utc);
    }

    private DateTime endDate
    {
        get => model.EndTime;
        set => model.EndTime = DateTime.SpecifyKind(value.Date.AddHours(23).AddMinutes(59), DateTimeKind.Utc);
    }

    private bool IsEditMode => Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsEditMode)
        {
            model = new LotUpsertModel
            {
                StartTime = DateTime.UtcNow.Date,
                EndTime = DateTime.UtcNow.Date.AddDays(7).AddHours(23).AddMinutes(59)
            };
            return;
        }

        var lot = await LotService.GetByIdAsync(Id!.Value);
        if (lot is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        model = LotUpsertModel.FromAuctionLot(lot);
    }

    private async Task HandleImageUploadAsync(InputFileChangeEventArgs e)
    {
        uploadErrorMessage = null;

        try
        {
            var file = e.File;
            if (file is null)
                return;

            var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };
            var extension = Path.GetExtension(file.Name).ToLowerInvariant();

            if (!allowedExtensions.Contains(extension))
            {
                uploadErrorMessage = "Please upload a JPG, PNG, GIF or WebP image.";
                return;
            }

            const long maxFileSize = 5 * 1024 * 1024;
            if (file.Size > maxFileSize)
            {
                uploadErrorMessage = "Image size must be 5MB or less.";
                return;
            }

            var uploadsFolder = Path.Combine(Env.WebRootPath, "uploads");
            if (!Directory.Exists(uploadsFolder))
            {
                Directory.CreateDirectory(uploadsFolder);
            }

            var newFileName = $"{Guid.NewGuid()}{extension}";
            var filePath = Path.Combine(uploadsFolder, newFileName);

            await using var fileStream = new FileStream(filePath, FileMode.Create);
            await file.OpenReadStream(maxFileSize).CopyToAsync(fileStream);

            model.ImageFileName = newFileName;
        }
        catch (Exception ex)
        {
            uploadErrorMessage = $"Image upload failed: {ex.Message}";
        }
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            var lot = model.ToAuctionLot();

            if (IsEditMode)
            {
                await LotService.UpdateAsync(lot);
            }
            else
            {
                await LotService.CreateAsync(lot);
            }

            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string GetImageUrl(string? fileName)
        => string.IsNullOrWhiteSpace(fileName) ? "/images/no-image.png" : $"/uploads/{fileName}";
}